---
import Link from '../atoms/Link.astro';
import Accordion from '../atoms/Accordion.astro';

import section from "../../data/text.json";

const testing = ["accordion_header", "accordion_content", "accordion_header_2", "accordion_content_2"];

const { data = {} } = Astro.props;
const { title, text_1, text_2, text_3, text_4, text_5, cta, textVariant, show } = data;

---

 <!-- Text variant = simple  -->
 {(textVariant === "simple" && 
<article class="">
    <h2 class="heading-large pb-6 md:pb-8">{title}</h2>
    <p class="body-base pt-2 md:pt-4 text-text-secondary">{text_1}</p>
    <p class="body-base pt-2 md:pt-4 text-text-secondary">{text_2}</p>
    <p class="body-base pt-2 md:pt-4 text-text-secondary">{text_3}</p>
    <p class="body-base pt-2 md:pt-4 text-text-secondary">{text_4}</p>
    <p class="body-base pt-2 md:pt-4 text-text-secondary">{text_5}</p>

   {(show === "true" &&  <div class="pt-8 md:pt-12"><Link variant = "ButtonSecondary" size ="large">{cta}</Link></div>)}
</article> )}




 <!-- Text variant = accordion  -->
{(textVariant === "accordion" && 
<article class="flex flex-col justify-between h-full">
  <div>
      <h2 class="heading-large pb-6 md:pb-8">{title}</h2>
      <p class="body-base pt-2 md:pt-4 text-text-secondary">{text_1}</p>
      <p class="body-base pt-2 md:pt-4 text-text-secondary">{text_2}</p>
      <p class="body-base pt-2 md:pt-4 text-text-secondary">{text_3}</p>
      <p class="body-base pt-2 md:pt-4 text-text-secondary">{text_4}</p>
      <p class="body-base pt-2 md:pt-4 text-text-secondary">{text_5}</p>
  </div>

 <div>

 {section
      .filter((item) => item.textVariant === "accordion")
      .map((item) =>
        item.accordion?.map((acc) => (
          <Accordion data={acc} />
        ))
      )
    }

     
 </div>
</article> )}



