import Link from '../atoms/Link.astro';
import Accordion from '../atoms/Accordion.astro';

import section from "../../data/text.json";

const { variant = "", overskrift="", show="", button_text = "" } = Astro.props;

// Find alle keys der starter med "text_"
const textFields = Object.keys(section)
  .filter(key => key.startsWith("text_"))
  .sort(); // text_1, text_2, ...
