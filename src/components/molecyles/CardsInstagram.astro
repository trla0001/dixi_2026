---
import { Image } from 'astro:assets';
import instagram from "../../assets/svg/instagram.svg";


const { img, href } = Astro.props;
---

<a href={href} target="_blank" class="group relative">
<Image src={instagram} alt="Instagram ikon" class="absolute top-4 right-4 z-10 md:top-6 md:right-6 
              transition-transform duration-800 ease-out

             group-hover:translate-x-[-1000%]
             group-hover:-translate-y-full" />

 <Image src={img} alt="Instagram billeder" width={600}
  height={600} class="object-cover w-full h-full rounded-sm md:rounded-lg transition duration-400 group-hover:brightness-50"  />
</a>