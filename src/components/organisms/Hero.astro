---
const { overskrift = "", bgImage = "" } = Astro.props;

const bgImagePath = `src/assets/images/${bgImage}.webp`;
---
<section
  style={`background-image: url('${bgImagePath}');`}
  class="min-h-103 md:min-h-138 h-[48vh] bg-bottom bg-cover flex">
  <h1 class="heading-display p-6 md:p-30 self-end">{overskrift}</h1>
</section>

