---
// Images.astro
const { data = {} } = Astro.props;
const { imageVariant, images = [] } = data;


---

{imageVariant === "single" && images.length > 0 && (
  <img class="rounded-sm md:rounded-lg aspect-3/4 object-cover" src={images[0].src} alt={images[0].alt} />
)}


<!-- {imageVariant === "grid" && (
  <div class="grid grid-cols-2 gap-4">
    {images.map((image) => (
      <img src={image.src} alt={image.alt} class="rounded-xs md:rounded-sm aspect-square object-cover" />
    ))}
  </div>
)} -->

{imageVariant === "grid" && (
  <div class="grid grid-cols-2 gap-4">
    
    <img
      src={images[0].src}
      alt={images[0].alt}
      class="w-full h-full aspect-square object-cover rounded-xs md:rounded-sm"
    />

    <img
      src={images[1].src}
      alt={images[1].alt}
      class="h-3/4 w-3/4 aspect-square object-cover rounded-xs md:rounded-sm self-end"
    />

   <div class="flex justify-end items-start">
      <img
        src={images[2].src}
        alt={images[2].alt}
        class="h-3/4 w-3/4 aspect-square object-cover rounded-xs md:rounded-sm"
      />
   </div>

    <img
      src={images[3].src}
      alt={images[3].alt}
      class="w-full h-full aspect-square object-cover rounded-xs md:rounded-sm"
    />

  </div>
)}
