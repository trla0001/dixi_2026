---
// Images.astro
const { variant = {}, item } = Astro.props;
---

{variant === "single" && item && item.images?.length > 0 && (
  <img
    src={item.images[0]}
    alt={item.alt}
    class="rounded-sm md:rounded-lg aspect-3/4"
    width="600"
    height="600"
  />
)}

{variant === "grid" && item && item.images?.length > 0 && (
  <article class="grid grid-cols-2 gap-4 lg:gap-6">
    {item.images.map((img, index) => (
      <img
        key={index}
        src={img}
        alt={item.alt}
        class="rounded-xs md:rounded-sm aspect-square object-cover"
      />
    ))}
  </article>
)}
