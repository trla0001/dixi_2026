---
 import { Image } from 'astro:assets';
import facaden from "../../assets/images/dummy.jpg";


const { variant = "", images = []} = Astro.props;

---

<!-- Et enkelt billede -->
{(variant === "single" && <Image width={600} height={600} src={images[0]} alt="" class="rounded-sm md:rounded-lg aspect-3/4"/>)}


<!-- Grid med 4 billeder -->
{(variant === "grid" && 

<article class="grid grid-cols-2 gap-4 lg:gap-6">
    
        <Image src={facaden} alt="" class="rounded-xs md:rounded-sm aspect-square"/>
        <Image src={facaden} alt="" class="rounded-xs md:rounded-sm aspect-square"/>
        <Image src={facaden} alt="" class="rounded-xs md:rounded-sm aspect-square"/>
        <Image src={facaden} alt="" class="rounded-xs md:rounded-sm aspect-square"/>
        
</article>


)}

