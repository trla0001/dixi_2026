---
const { overskrift = ""} = Astro.props;
---

<details class="py-6 px-4 border-b border-b-border-primary hover:bg-background-secondary">
  <summary class="body-large font-medium cursor-pointer flex justify-between">{overskrift}</summary>
  <article class="body-small pt-8 md:pr-[25%]">
   <slot></slot>
  </article>
</details>

<style>
      /* Arrow icon */
  details summary::after {
    /* content: url(/img/svg/arrow_down.svg); */
    content: url(src/assets/svg/add.svg);
  }
  details[open] > summary::after {
   content: url(src/assets/svg/remove.svg);
  }
</style>