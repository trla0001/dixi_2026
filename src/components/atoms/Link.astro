---
// Henter parametrene fra Astro.props
const { href = "#", target = "_self", variant = "", size = "" } = Astro.props;

const linkStyling = "";

const variantClasses = {
  ButtonPrimary: "block text-center rounded-full body-base text-text-brand-dark hover:text-text-brand-light bg-background-brand-primary hover:bg-background-brand-secondary focus:outline-2 focus:focus:outline-border-brand",
  ButtonSecondary: "text-center rounded-full body-base text-text-primary outline outline-border-primary hover:bg-background-secondary focus:outline-2 focus:focus:outline-border-primary",
  ButtonInverted: "text-center rounded-full body-base text-text-alternate hover:text-text-primary bg-background-alternate hover:bg-transparent hover:outline hover:outline-border-secondary focus:outline-2",
  NavLink: "block body-base text-text-primary no-underlin hover:border-b  hover:border-border-brand focus:outline-2 focus:focus:outline-border-secondary",
};

const sizeClasses = {
  large: "py-3 px-7",
  medium: "py-2 px-6",
  base: "py-6",
};

// Tjek om linket er aktivt
const isActive = Astro.url.pathname === href;

// Tilføj underline permanent hvis aktiv
const activeClass = isActive ? "border-b border-border-brand" : "";
---

<a href={href} class="" target={target} class:list={[linkStyling, variantClasses[variant], sizeClasses[size], activeClass]}><slot /></a>
