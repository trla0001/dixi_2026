---
const { variant = "", size = "" } = Astro.props;

const buttonStyling = "transition duration-200";

const variantClasses = {
  primary: "bg-sky-800 text-white hover:bg-sky-600",
  secondary: "border-2 bg-white border-black text-black hover:border-sky-600 hover:text-sky-600",
};

const sizeClasses = {
  large: "p-12",
  medium: "py-2 px-5",
  small: "p-3",
};
---

<div>
  <button class:list={[buttonStyling, variantClasses[variant], sizeClasses[size]]}><slot /></button>
</div>
