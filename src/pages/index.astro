---
import MainLayout from "../layouts/MainLayout.astro";
import Link from '../components/atoms/Link.astro';
import SocialProof from "../components/molecyles/SocialProof.astro";
import CTABanner from "../components/organisms/CTABanner.astro";
import SectionWrapper from "../components/organisms/SectionWrapper.astro";



import { Image } from 'astro:assets';
import facaden from "../assets/images/forside/facaden.webp";
---


<MainLayout title="Dixi Burger / Madbod på Roskilde Festival 2026" description="Vil du være frivillig hos Dixi Burger på Roskilde Festival? Med din indsats i vores madbod er du med til at støtte KFUM’s Boldklub Roskilde" og:title="Dixi-Burger / Frivillig på Roskilde Festival 2026" og:description="Vil du være frivillig hos Dixi Burger på Roskilde Festival? Med din indsats i vores madbod er du med til at støtte KFUM’s Boldklub Roskilde">
	<section id="hero">
		<article class="section-main min-h-[65vh] flex flex-col justify-end items-start">
			<h1 class="heading-display pb-6 md:pb-8">Bliv en del af Dixi</h1>
			<p class="body-large pb-6 md:pb-8 max-w-136">Bag Dixi Burger står hundredvis af frivillige, der siden 2010 har drevet vores madbod på Roskilde Festival og serveret tusindvis af burgere for festivalens gæster.</p>
			<Link variant="ButtonSecondary" size="large" href="https://www.kfumfestival.dk/festival/" target="_blank">Tilmeld dig</Link>
		</article>
		<Image src={facaden} alt="Billede af Dixi Burger madbodens facade" widths={[400, 800, 1200, 1600]}
  sizes="(max-width: 768px) 100vw, 800px" />
	</section>

	<section id="info" class="section-main pt-12 md:pt-20 lg:pt-30 md:grid md:grid-cols-[1fr_2fr] md:gap-4 lg:gap-6">
		 <h2 class="heading-large pb-6">Mere end en madbod</h2>
        <section class="md:max-w-183 md:justify-self-end">
	      <div class="body-base text-text-secondary pb-8 md:pb-20">
	      	  <p class="pb-4">Hos Dixi Burger er vi mere end blot en madbod. Vi er en frivilligdrevet organisation, der har været en fast del af Roskilde Festival siden 2010, men vores rødder strækker sig helt tilbage til KFUM’s Boldklub Roskildes første deltagelse i 1971.</p>
		      <p>Med din indsats i boden støtter du KFUM’s Boldklub Roskilde og klubbens indsats for udvikling af unge fodboldspillere, samt vedligehold af faciliteter.</p>
	      </div>
		  <div class="flex flex-col gap-6 md:flex-row justify-between">
              <SocialProof tal="350" text="Frivillige"/>
              <SocialProof tal="45.000+" text="Solgte burgere"/>
              <SocialProof tal="10.000.000+" text="Indsamlet til KFUM Boldklub Roskilde"/>
		    </div>
        </section>
	</section>

  <SectionWrapper  sectionId={1} />
  <SectionWrapper  sectionId={2} />
  <CTABanner/>
</MainLayout>